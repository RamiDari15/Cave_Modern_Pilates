# Cave Modern Pilates website/backend env
# Copy this to .env and fill the blank values.
#
# Private secrets belong here, not in the Expo mobile app .env.

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8765
HOST=127.0.0.1
PUBLIC_BASE_URL=https://www.cavemodernpilates.com
SITE_URL=https://www.cavemodernpilates.com
VITE_SITE_URL=https://www.cavemodernpilates.com
SESSION_SECRET=replace_with_a_long_random_secret
DISABLE_SECURE_COOKIES=false
DEBUG_ENABLED=false

# ── Supabase contact form ─────────────────────────────────────────────────────
# Required for POST /api/contact.
SUPABASE_URL=
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Mindbody core / Public API ────────────────────────────────────────────────
BOOKING_API_KEY=
BOOKING_SITE_ID=5753835
BOOKING_LOCATION_ID=1
BOOKING_TEST_MODE=false

# Optional aliases supported by the code:
# MINDBODY_API_KEY=
# MINDBODY_SITE_ID=5753835
# MINDBODY_LOCATION_ID=1

# ── Studio cache / schedule refresh ───────────────────────────────────────────
BOOKING_CACHE_SYNC=true
BOOKING_SYNC_ON_START=true
BOOKING_CACHE_REFRESH_MINUTES=15
BOOKING_SCHEDULE_REFRESH_SECONDS=600

# ── Mindbody OAuth client sign-in ─────────────────────────────────────────────
# Create the OAuth client at:
# https://developers.mindbodyonline.com/Account/Credentials
BOOKING_OAUTH_AUTHORIZE_URL=https://signin.mindbodyonline.com/connect/authorize
BOOKING_OAUTH_TOKEN_URL=https://signin.mindbodyonline.com/connect/token
BOOKING_OAUTH_CLIENT_ID=
BOOKING_OAUTH_CLIENT_SECRET=
BOOKING_OAUTH_REDIRECT_URI=https://www.cavemodernpilates.com/api/auth/callback
BOOKING_OAUTH_SUBSCRIBER_ID=5753835
BOOKING_OAUTH_SCOPE=email openid profile offline_access Platform.Contacts.Api.Write Platform.Contacts.Api.Read Platform.Accounts.Api.Read Mindbody.Api.Public.v6 Platform.ProductInventory.Api.Read Platform.ProductInventory.Api.Write
BOOKING_OAUTH_RESPONSE_MODE=form_post
BOOKING_OAUTH_RESPONSE_TYPE=code id_token
BOOKING_OAUTH_USE_PKCE=false
BOOKING_OAUTH_INCLUDE_SUBSCRIBER_ID=false

# Optional aliases supported by the code:
# MINDBODY_OAUTH_AUTHORIZE_URL=https://signin.mindbodyonline.com/connect/authorize
# MINDBODY_OAUTH_TOKEN_URL=https://signin.mindbodyonline.com/connect/token
# MINDBODY_OAUTH_CLIENT_ID=
# MINDBODY_OAUTH_CLIENT_SECRET=
# MINDBODY_OAUTH_REDIRECT_URI=https://www.cavemodernpilates.com/api/auth/callback
# MINDBODY_OAUTH_SUBSCRIBER_ID=5753835
# MINDBODY_OAUTH_SCOPE=
# MINDBODY_OAUTH_RESPONSE_MODE=form_post
# MINDBODY_OAUTH_RESPONSE_TYPE=code id_token
# MINDBODY_OAUTH_USE_PKCE=false
# MINDBODY_OAUTH_INCLUDE_SUBSCRIBER_ID=false

# ── Mindbody action token for booking/buying/profile updates ─────────────────
# Preferred: Source Credentials from Mindbody developer portal.
BOOKING_SOURCE_NAME=
BOOKING_SOURCE_PASSWORD=

# Optional fallback only if Mindbody gives you staff credentials or a token.
BOOKING_STAFF_USERNAME=
BOOKING_STAFF_PASSWORD=
BOOKING_STAFF_TOKEN=

# Optional aliases supported by the code:
# MINDBODY_SOURCE_NAME=
# MINDBODY_SOURCE_PASSWORD=
# MINDBODY_STAFF_USERNAME=
# MINDBODY_STAFF_PASSWORD=
# MINDBODY_STAFF_TOKEN=
# BOOKING_USER_USERNAME=
# BOOKING_USER_PASSWORD=
# BOOKING_USER_TOKEN=
# MINDBODY_USER_USERNAME=
# MINDBODY_USER_PASSWORD=
# MINDBODY_USER_TOKEN=

# ── Payments / saved cards ────────────────────────────────────────────────────
# Hosted Mindbody-approved page for clients to add a saved card.
BOOKING_PAYMENT_SETUP_URL=
BOOKING_PAYMENT_AUTH_CALLBACK_URL=

# Optional aliases supported by the code:
# MINDBODY_PAYMENT_SETUP_URL=
# MINDBODY_PAYMENT_AUTH_CALLBACK_URL=

# ── Pricing/catalog behavior ─────────────────────────────────────────────────
# Optional comma-separated service IDs that count as New Client/Newbie promos.
NEWBIE_SERVICE_IDS=

# ── Liability waiver custom client fields ────────────────────────────────────
# Create these custom client fields in Mindbody, then paste the IDs here.
BOOKING_WAIVER_CUSTOM_FIELD_ID=
BOOKING_WAIVER_SIGNATURE_FIELD_ID=
BOOKING_WAIVER_DATE_FIELD_ID=
BOOKING_WAIVER_VERSION_FIELD_ID=

# Optional aliases supported by the code:
# MINDBODY_WAIVER_CUSTOM_FIELD_ID=
# MINDBODY_WAIVER_SIGNATURE_FIELD_ID=
# MINDBODY_WAIVER_DATE_FIELD_ID=
# MINDBODY_WAIVER_VERSION_FIELD_ID=
