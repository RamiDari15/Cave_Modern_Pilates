BOOKING_API_KEY=your_api_key_here
BOOKING_SITE_ID=5753835
BOOKING_LOCATION_ID=1
SESSION_SECRET=replace_with_a_long_random_secret
PORT=8765
HOST=127.0.0.1

# Required for Mindbody OAuth client sign-in.
# Create the OAuth client at https://developers.mindbodyonline.com/Account/Credentials
# after Mindbody API Support approves OAuth for the account.
BOOKING_OAUTH_AUTHORIZE_URL=https://signin.mindbodyonline.com/connect/authorize
BOOKING_OAUTH_TOKEN_URL=https://signin.mindbodyonline.com/connect/token
BOOKING_OAUTH_CLIENT_ID=your_oauth_client_id
BOOKING_OAUTH_CLIENT_SECRET=your_oauth_client_secret
BOOKING_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/api/auth/callback
BOOKING_OAUTH_SUBSCRIBER_ID=5753835
BOOKING_OAUTH_SCOPE=email profile openid offline_access Mindbody.Api.Public.v6

# Required for direct on-site class pack/drop-in checkout through /sale/checkoutshoppingcart.
# Mindbody returns "staff level or higher user token required" for that endpoint.
BOOKING_STAFF_TOKEN=staff_level_user_token_for_checkout

# Optional aliases also supported by the dev API proxy:
# MINDBODY_API_KEY=your_api_key_here
# MINDBODY_SITE_ID=5753835
# MINDBODY_OAUTH_CLIENT_ID=your_oauth_client_id
# MINDBODY_OAUTH_CLIENT_SECRET=your_oauth_client_secret
