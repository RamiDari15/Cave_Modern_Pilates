BOOKING_API_KEY=your_api_key_here
BOOKING_SITE_ID=5753835
BOOKING_LOCATION_ID=1
SESSION_SECRET=replace_with_a_long_random_secret
PORT=8765
HOST=127.0.0.1
PUBLIC_BASE_URL=https://cavemodernpilates.com

# Server-side public cache refresh.
# Public pages read data/studio-cache.json first; the backend refreshes that cache on an interval.
BOOKING_CACHE_SYNC=true
BOOKING_SYNC_ON_START=true
BOOKING_CACHE_REFRESH_MINUTES=15

# Required for Mindbody OAuth client sign-in.
# Create the OAuth client at https://developers.mindbodyonline.com/Account/Credentials
# after Mindbody API Support approves OAuth for the account.
BOOKING_OAUTH_AUTHORIZE_URL=https://signin.mindbodyonline.com/connect/authorize
BOOKING_OAUTH_TOKEN_URL=https://signin.mindbodyonline.com/connect/token
BOOKING_OAUTH_CLIENT_ID=your_oauth_client_id
# Optional. Leave blank for a public OAuth client unless Mindbody gives you a confidential-client secret.
BOOKING_OAUTH_CLIENT_SECRET=
BOOKING_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/callback
BOOKING_OAUTH_SUBSCRIBER_ID=5753835
BOOKING_OAUTH_SCOPE=email openid profile Platform.Contacts.Api.Write Platform.Contacts.Api.Read Platform.Accounts.Api.Read Mindbody.Api.Public.v6 Platform.ProductInventory.Api.Read Platform.ProductInventory.Api.Write
BOOKING_OAUTH_RESPONSE_MODE=form_post
BOOKING_OAUTH_RESPONSE_TYPE=code id_token
BOOKING_OAUTH_USE_PKCE=false
# Leave false unless Mindbody specifically tells you this OAuth client requires subscriberId in authorize/token requests.
BOOKING_OAUTH_INCLUDE_SUBSCRIBER_ID=false

# Required for booking, canceling, buying, and waiver profile sync.
# Mindbody confirmed OAuth consumer tokens only work with GET /client/clientcompleteinfo.
# Use a Staff/User token or a token derived from approved Source Credentials for Public API actions.
BOOKING_STAFF_TOKEN=staff_or_source_derived_user_token
# Optional alias supported by the backend:
# BOOKING_USER_TOKEN=staff_or_source_derived_user_token

# Required to store the signed liability waiver inside the Mindbody client profile.
# Create custom client fields in Mindbody, then place the field IDs here.
BOOKING_WAIVER_CUSTOM_FIELD_ID=
BOOKING_WAIVER_SIGNATURE_FIELD_ID=
BOOKING_WAIVER_DATE_FIELD_ID=
BOOKING_WAIVER_VERSION_FIELD_ID=

# Optional aliases also supported by the dev API proxy:
# MINDBODY_API_KEY=your_api_key_here
# MINDBODY_SITE_ID=5753835
# MINDBODY_OAUTH_CLIENT_ID=your_oauth_client_id
# MINDBODY_OAUTH_CLIENT_SECRET=
